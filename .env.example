# Verun Genesis — Environment Variables
# Copy to .env.local for local dev, set in Vercel Dashboard for production

# Stellar Testnet Service Account
# Generate with: node -e "const sdk=require('@stellar/stellar-sdk'); const kp=sdk.Keypair.random(); console.log(kp.secret(), kp.publicKey())"
# Fund testnet account: https://friendbot.stellar.org?addr=YOUR_PUBLIC_KEY
STELLAR_SECRET_KEY=SB...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Certificate signing secret (any random string, keep private)
VERUN_SIGNING_SECRET=change-this-to-a-random-secret

# Genesis cap (default: 10000, never increase without validator vote)
GENESIS_CAP=10000
INVITE_ONLY_UNTIL=1000
